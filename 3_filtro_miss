vcftools --gzvcf "$OUTDIR/${CHR}.dp5_maxmiss0.1.recode.vcf.gz" --missing-indv --out "$OUTDIR/missing_indv_after"
bcftools stats "$OUTDIR/${CHR}.dp5_maxmiss0.1.recode.vcf.gz" > "$OUTDIR/bcftools_stats_after.txt"

# 6) confronto rapido numerico
