Identifica, per ogni cromosoma, le varianti uniche di UNITUS, CNR e LONG (presenti in un solo dataset) e le salva in tre VCF distinti
#!/bin/bash
#SBATCH -J isec_unique_1_24
#SBATCH -A IscrB_VIROME
#SBATCH -p g100_usr_prod
#SBATCH -n 12
#SBATCH --mem=120G
#SBATCH -t 3:00:00
#SBATCH --mail-user=bencyfra@gmail.com
#SBATCH --mail-type=ALL

module load profile/bioinf
module load autoload bcftools

BASE_UNITUS="/g100_scratch/userexternal/carcuri0/analisi_paper_francesca/3_filtro_miss"
BASE_CNR="/g100_scratch/userexternal/carcuri0/merge_vcf_new/vcf_cnr/vcf_cnr_renamed/vcf_cnr_normalized"
BASE_LONG="/g100_scratch/userexternal/carcuri0/merge_vcf_new/vcf_long"

for chr in {1..24} X; do
  unitus="${BASE_UNITUS}/filter_miss_chr${chr}/chr${chr}.dp5_maxmiss0.1.recode.vcf.gz"
  cnr="${BASE_CNR}/CNR.chr.${chr}.norm.vcf.gz"
  long="${BASE_LONG}/chr${chr}.recode.vcf.gz"

  out="isec_unique_chr${chr}"
  mkdir -p "$out"

  # UNICHE (presenti in esattamente 1 file)
  bcftools isec -n=1 -c all -p "$out" "$unitus" "$cnr" "$long"

  # Rinomina + comprimi se esistono
  [[ -f "$out/0000.vcf" ]] && mv "$out/0000.vcf" "$out/unitus_unique_chr${chr}.vcf"
  [[ -f "$out/0001.vcf" ]] && mv "$out/0001.vcf" "$out/cnr_unique_chr${chr}.vcf"
  [[ -f "$out/0002.vcf" ]] && mv "$out/0010.vcf" "$out/long_unique_chr${chr}.vcf"

  for f in "$out"/{unitus,cnr,long}_unique_chr${chr}.vcf; do
    [[ -f "$f" ]] || continue
    bgzip -f "$f"
    bcftools index -f "${f}.gz"
  done
  echo "chr${chr} fatto → ${out}/(unitus|cnr|long)_unique_chr${chr}.vcf.gz”

