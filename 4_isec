Questo script trova le varianti comuni per ogni cromosoma tra il dataset Unitus filtrato e il dataset CNR.
#!/bin/bash
#SBATCH -J isec_commons_unitus_cnr
#SBATCH -A IscrB_VIROME
#SBATCH -p g100_usr_prod
#SBATCH -n 8
#SBATCH --mem=40G
#SBATCH -t 01:00:00
#SBATCH --mail-user=bencyfra@gmail.com
#SBATCH --mail-type=ALL

module load profile/bioinf
module load autoload bcftools
BASE_UNITUS="/g100_scratch/userexternal/carcuri0/analisi_paper_francesca/3_filtro_miss"
BASE_CNR="/g100_scratch/userexternal/carcuri0/merge_vcf_new/vcf_cnr/vcf_cnr_renamed/vcf_cnr_normalized"

# cromosomi: 1..24 + X + MT
for chr in {1..24} X MT; do
  unitus="${BASE_UNITUS}/filter_miss_chr${chr}/chr${chr}.dp5_maxmiss0.1.recode.vcf.gz"
  cnr="${BASE_CNR}/CNR.chr.${chr}.norm.vcf.gz"

  outdir="isec_commons_unitus_cnr/chr${chr}"
  mkdir -p "$outdir"

  echo ">>> chr${chr}"
  echo "    unitus: $unitus"
  echo "    cnr   : $cnr"

  # Intersezione tra i due file (presenti in entrambi)
  bcftools isec -n=2 -c all -p "$outdir" "$unitus" "$cnr"

  # Per 2 input, l'intersezione sta in 0002.vcf
  if [[ -f "$outdir/0002.vcf" ]]; then
    mv "$outdir/0002.vcf" "$outdir/unitus_cnr_common_chr${chr}.vcf"
    bgzip -f "$outdir/unitus_cnr_common_chr${chr}.vcf"
    bcftools index -f "$outdir/unitus_cnr_common_chr${chr}.vcf.gz"
    echo "    [OK] $outdir/unitus_cnr_common_chr${chr}.vcf.gz"
  else
    echo "    [NO VARIANTS] Nessuna intersezione per chr${chr}"
  fi
done






