  n = .N,
  min_CR = min(CR, na.rm=TRUE),
  Q1     = quantile(CR, 0.25, na.rm=TRUE, type=7),
  median = quantile(CR, 0.50, na.rm=TRUE, type=7),
  Q3     = quantile(CR, 0.75, na.rm=TRUE, type=7),
  max_CR = max(CR, na.rm=TRUE),
  IQR    = IQR(CR, na.rm=TRUE)
), by = Subset][order(Subset)]

stats_box[, `:=`(
  lower_whisker = pmax(min_CR, Q1 - 1.5*IQR),
  upper_whisker = pmin(max_CR, Q3 + 1.5*IQR)
)]

