HEATMAP DENSITA’
options(stringsAsFactors = FALSE, scipen = 999, digits = 15)
rm(list = ls()); gc()
IN_DIR   <- "~/Desktop/common_biallelic_snp"     # cartella coi VCF
PATTERN  <- "commons_.*_biallelic.*\\.vcf(\\.gz)?$"
CHR_SET  <- c(as.character(1:24), "X", "Y")      # includo X e Y
WINDOW   <- 1e6                                  # 1 Mbp

need <- c("data.table", "ggplot2", "grid")
to_install <- need[!(need %in% rownames(installed.packages()))]
if (length(to_install)) install.packages(to_install)
library(data.table); library(ggplot2); library(grid)

IN_DIR <- path.expand(IN_DIR)
if (!dir.exists(IN_DIR)) stop("IN_DIR non esiste: ", IN_DIR)
vcfs <- list.files(IN_DIR, pattern = PATTERN, full.names = TRUE)
if (!length(vcfs)) stop("Nessun file trovato in IN_DIR.")

chr_from_name <- function(x) {
  sub("^.*?(?:chr)?([0-9]{1,2}|2[0-4]|X|Y|MT).*$", "\\1",
      basename(x), perl = TRUE)
}
read_pos <- function(f, chr_label) {
  cmd <- sprintf("bcftools query -f '%%POS\\n' %s", shQuote(f))
  dt  <- fread(cmd = cmd, header = FALSE, showProgress = FALSE)
  setnames(dt, "V1", "Position")
  dt[, CHR := as.character(chr_label)]
  dt[]
}
lst <- vector("list", length(vcfs))
for (i in seq_along(vcfs)) {
  chr <- chr_from_name(vcfs[i])
  lst[[i]] <- read_pos(vcfs[i], chr)
}
snpX <- rbindlist(lst, use.names = TRUE, fill = TRUE)

snpX <- snpX[CHR %in% CHR_SET]

snpX[, Position := as.numeric(Position)]
snpX <- snpX[is.finite(Position)]
snpX[, CHR := factor(CHR, levels = CHR_SET)]

if (!nrow(snpX)) stop("Nessun SNP dopo il filtro CHR_SET.")

chr_len <- snpX[, .(max_pos = max(Position, na.rm = TRUE)), by = CHR]
chr_len[, nbins := ceiling(max_pos / WINDOW)]
max_len_all <- max(chr_len$max_pos, na.rm = TRUE)
range_Mb    <- max_len_all / 1e6

all_bins <- chr_len[, {
  starts <- seq(0, nbins - 1) * WINDOW
  data.table(
    bin   = seq_len(nbins),
    start = starts,
    end   = pmin(starts + WINDOW, max_pos)
  )
}, by = CHR]

snpX[, bin := floor(Position / WINDOW) + 1L]
counts <- snpX[, .N, by = .(CHR, bin)]

bins_dt <- merge(all_bins, counts, by = c("CHR", "bin"), all.x = TRUE)
bins_dt[is.na(N), N := 0L]
bins_dt[, start_Mb := start / 1e6]
bins_dt[, width_Mb := (end - start) / 1e6]

q <- quantile(bins_dt$N, c(0.01, 0.99), na.rm = TRUE)
CAP_MIN <- 0L
CAP_MAX <- max(ceiling(q[2] / 1000) * 1000, 1000L)
bins_dt[, N_cap := pmin(N, CAP_MAX)]

brks <- pretty(c(CAP_MIN, CAP_MAX), n = 6)
brks <- brks[brks >= CAP_MIN & brks <= CAP_MAX]
labs <- sprintf("%.0f", brks)

pal <- colorRampPalette(c(
  "#00441B","#2A7C3A","#7FC97F",
  "#FFFFBF","#FDBF6F","#F46D43","#D73027"
))(length(brks) - 1)

mean_density_per_1Mbp <- mean(bins_dt$N, na.rm = TRUE)
sd_density_per_1Mbp   <- sd(bins_dt$N, na.rm = TRUE)

cat(sprintf("\nMean genome-wide SNP density: %.2f SNPs per 1 Mbp (±%.2f SD)\n",
            mean_density_per_1Mbp, sd_density_per_1Mbp))

out_dir <- file.path("~", "Desktop", "DensityHeatmap_1Mbp")
dir.create(out_dir, showWarnings = FALSE, recursive = TRUE)

fwrite(bins_dt[, .(CHR, bin, start, end, N)],
       file.path(out_dir, "density_1Mbp_counts.csv"))

x_breaks <- pretty(c(0, range_Mb), n = 7)

png(file.path(out_dir, "heatmap_density_1Mbp.png"),
    width = 36, height = 10, units = "in", res = 600)

ggplot(bins_dt, aes(x = start_Mb, y = CHR, fill = N_cap)) +
  geom_tile(aes(width = width_Mb, height = 0.8)) +
  scale_y_discrete(limits = rev) +
  scale_x_continuous(
    expand = expansion(c(0.005, 0.01)),
    limits = c(0, range_Mb),
    breaks = x_breaks,
    labels = function(x) sprintf("%d Mbp", x)
  ) +
  scale_fill_gradientn(
    colors = pal,
    limits = c(CAP_MIN, CAP_MAX),
    breaks = brks,
    labels = labs,
    guide = guide_colorbar(
      title     = "SNPs / 1 Mbp",
      barheight = unit(12, "lines"),
      barwidth  = unit(1.2, "cm")
    )
  ) +
  labs(
    title = "Number of SNPs within 1 Mbp windows",
    x = NULL, y = NULL
  ) +
  theme_minimal(base_size = 18) +
  theme(
    panel.grid        = element_blank(),
    
    axis.text.y       = element_text(size = 16, colour = "black", face = "bold"),
    axis.text.x       = element_text(size = 18, colour = "black", face = "bold"),
    plot.title        = element_text(size = 22, face = "bold", colour = "black", hjust = 0),

    legend.position   = "right",
    legend.title      = element_text(size = 18, face = "bold", colour = "black"),
    legend.text       = element_text(size = 16, face = "bold", colour = "black"),
    legend.background = element_rect(fill = "white", colour = NA)
  )
dev.off()
cat("\n========================================\n")
cat(" Genome-wide SNP density (1 Mbp windows)\n")
cat("========================================\n")
cat(sprintf("Mean SNP density: %.2f SNPs per 1 Mbp\n", mean_density_per_1Mbp))
cat(sprintf("Standard deviation: %.2f SNPs per 1 Mbp\n", sd_density_per_1Mbp))
cat("========================================\n\n")















