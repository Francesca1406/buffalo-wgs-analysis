for (DT in list(med_lmiss, riv_lmiss, swa_lmiss)) {
  DT[, CR := 1 - F_MISS]
}
threshold <- 0.90
med_pass <- med_lmiss[CR >= threshold]

setkey(med_pass, CHR, POS)
setkey(riv_lmiss, CHR, POS)
setkey(swa_lmiss, CHR, POS)

riv_filtered <- riv_lmiss[med_pass, nomatch=0]
swa_filtered <- swa_lmiss[med_pass, nomatch=0]

