# === CICLO PRINCIPALE PER TUTTI I SUBSET E TUTTI I CROMOSOMI ===
# === CICLO PRINCIPALE PER TUTTI I SUBSET E TUTTI I CROMOSOMI ===
for name, folder in vcf_files.items():
    print(f"\n--- Elaborazione {name} ---")
    baf_out = os.path.join(output_folder, f"{name}_BAF.txt")

    # cerca tutti i VCF per-cromosoma nella sottocartella
    pattern = os.path.join(BASE, folder, f"chr*_subset_{folder.split('_')[1].upper()}.recode.vcf")
    vcfs_chr = sorted(glob.glob(pattern))
    if not vcfs_chr:
        print(f"⚠️  Nessun file trovato in {folder}")
        continue

    print(f"Trovati {len(vcfs_chr)} file per {folder}")
    partials = []

    for vcf in vcfs_chr:
        chr_name = os.path.basename(vcf).split('_')[0]
        out_chr = os.path.join(output_folder, f"{name}_{chr_name}_BAF.txt")
        print(f"  Estrai BAF: {vcf} → {out_chr}")
        estrai_baf(vcf, out_chr)
        partials.append(out_chr)

    # concatena tutti i cromosomi
    with open(baf_out, "w") as w:
        for i, f in enumerate(partials):
            with open(f) as r:
                for j, line in enumerate(r):
                    if i > 0 and j == 0:
                        continue
                    w.write(line)

    print(f"→ Unito {len(partials)} file in {baf_out}")

    # calcola medie BAF
    group_key = name.upper() if name != 'riv_all' else 'RIV_ALL'
    calcola_medie_baf(baf_out, {group_key: groups[group_key]}, output_folder)


