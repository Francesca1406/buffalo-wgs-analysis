# === FUNZIONE PER ESTRARRE BAF ===
def estrai_baf(infile, outfile):
    start_time = time.time()
    opener = gzip.open if infile.endswith('.gz') else open
    with opener(infile, "rt") as f_in, open(outfile, "w") as f_out:
        ii = 0
	animdiz = []  # stessa indentazione di "ii = 0"
        for line in f_in:
            cols = line.strip().split('\t')
            if len(cols) < 10:
                continue
            ii += 1
            if ii == 1:
                # Header VCF
                cro, pos, idd, ref, alt, qual, fil, info, form, anims = line.strip().split('\t', 9)
                anim = anims.split('\t')
                animdiz = list(anim)
                f_out.write(f"{cro}\t{pos}\t{ref}\t{alt}\t" + "\t".join(animdiz) + "\n")
            else:
                cro = cols[0]
                pos = cols[1]
                ref = cols[3]
                alt = cols[4]
                genofield = cols[8].split(':')
                try:
                    posAD = genofield.index('AD')
                    posDP = genofield.index('DP')
                except ValueError:
                    print(f"Attenzione: campo AD o DP mancante alla riga {ii}")
                    continue
                teste = []
                for gt in range(len(cols) - 9):
                    genosanimal = cols[gt + 9]
                    genoanimal = genosanimal.split(':')
                    if len(genoanimal) <= max(posAD, posDP):
                        teste.append('NA')
                        continue
                    allele = genoanimal[posAD]
                    if ',' not in allele:
                        teste.append('NA')
                        continue
                    try:
                        alleleDP = int(genoanimal[posDP])
                        alleleref = int(allele.split(',')[0])
                        allelealt = int(allele.split(',')[1])
                        freqalt = round(allelealt / alleleDP, 4) if alleleDP > 0 else 0
                        teste.append(str(freqalt))
                    except:
                        teste.append('NA')
                f_out.write(f"{cro}\t{pos}\t{ref}\t{alt}\t" + "\t".join(teste) + "\n")
    print(f"File {outfile} scritto in {round(time.time() - start_time, 2)} sec")


# === FUNZIONE PER CALCOLARE LE MEDIE BAF ===
def calcola_medie_baf(input_file, groups_dict, output_folder):
    df = pd.read_csv(input_file, sep='\t', low_memory=False)
    print(f"Lettura {input_file} completata, shape: {df.shape}")

    # Pulizia & numerico
    df.replace(['.', ''], np.nan, inplace=True)
    for col in df.columns[4:]:
        df[col] = pd.to_numeric(df[col], errors='coerce')

    # Medie per gruppo
    for group_name, sample_cols in groups_dict.items():
        missing_cols = [c for c in sample_cols if c not in df.columns]
        if missing_cols:
            print(f"Attenzione: colonne mancanti per {group_name}: {missing_cols[:5]}{'...' if len(missing_cols)>5 else ''}")
        present_cols = [c for c in sample_cols if c in df.columns]
        df[f'Mean_{group_name}'] = df[present_cols].mean(axis=1) if present_cols else np.nan

    # Colonne finali
    cols_to_save = list(df.columns[:4]) + [c for c in df.columns if c.startswith('Mean_')]

    # Salva
    base = os.path.basename(input_file).replace('_BAF.txt', '')
    output_file = os.path.join(output_folder, f"{base}_mean_freq.csv")
    df[cols_to_save].to_csv(output_file, index=False)
    print(f"File medie salvato in {output_file}")


